    "deployment_diagram": "graph TB\n    subgraph \"AWS EU-West-1 (Primary)\"\n        subgraph \"EKS Cluster\"\n            A1[API Gateway]\n            A2[Auth Service]\n            A3[Messaging Service]\n            A4[Group Service]\n            A5[Call Service]\n        end\n        B1[RDS PostgreSQL]\n        B2[ElastiCache Redis]\n        B3[MSK Kafka]\n        B4[S3 Bucket]\n        B5[CloudFront CDN]\n    end\n    \n    subgraph \"AWS US-East-1 (Failover)\"\n        subgraph \"EKS Cluster Standby\"\n            C1[API Gateway]\n            C2[Auth Service]\n            C3[Messaging Service]\n        end\n        D1[RDS Read Replica]\n        D2[S3 Cross-Region Replication]\n    end\n    \n    E[Route 53] --> B5\n    B5 --> A1\n    A1 --> A2\n    A1 --> A3",
    "data_flow_diagram": "flowchart LR\n    A[Mobile Client] --> B[CDN]\n    A --> C[API Gateway]\n    C --> D[Auth Service]\n    C --> E[Messaging Service]\n    C --> F[WebSocket Gateway]\n    \n    D --> G[User DB]\n    E --> H[Message DB]\n    E --> I[Kafka]\n    F --> J[Redis]\n    \n    I --> K[Notification Service]\n    I --> L[Search Service]\n    L --> M[Elasticsearch]\n    \n    E --> N[Encryption Service]\n    N --> O[Vault]\n    \n    P[Media Service] --> Q[S3 Storage]\n    Q --> B",
