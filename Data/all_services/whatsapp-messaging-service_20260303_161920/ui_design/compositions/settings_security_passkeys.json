        "variant": "default",
        "title": "Passkeys",
        "showBackButton": true
      },
      "position": "header",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-001",
      "component_name": "Button",
      "props": {
        "variant": "primary",
        "text": "Add Passkey",
        "icon": "plus"
      },
      "position": "main",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-024",
      "component_name": "DeviceListItem",
      "props": {
        "variant": "active",
        "showActions": true,
        "allowDelete": true
      },
      "position": "main",
      "responsive": {
        "mobile": "stacked",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-001",
      "component_name": "Button",
      "props": {
        "variant": "danger",
        "text": "Delete",
        "size": "small"
      },
      "position": "main",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-021",
      "component_name": "EncryptionBadge",
      "props": {
        "variant": "secure"
      },
      "position": "main",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-026",
      "component_name": "ToastNotification",
      "props": {
        "variant": "success",
        "message": "Passkey added successfully"
      },
