      "component_name": "ProfileHeader",
      "props": {
        "title": "Geräte-Übersicht",
        "variant": "default"
      },
      "position": "header",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-002",
      "component_name": "SearchBar",
      "props": {
        "placeholder": "Geräte durchsuchen...",
        "variant": "default"
      },
      "position": "main",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-024",
      "component_name": "DeviceListItem",
      "props": {
        "variant": "active",
        "showStatus": true,
        "showLastSeen": true
      },
      "position": "main",
      "responsive": {
        "mobile": "stacked",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-024",
      "component_name": "DeviceListItem",
      "props": {
        "variant": "inactive",
        "showStatus": true,
        "showLastSeen": true
      },
      "position": "main",
      "responsive": {
        "mobile": "stacked",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-021",
      "component_name": "EncryptionBadge",
      "props": {
        "variant": "secure"
      },
      "position": "main",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-001",
      "component_name": "Button",
      "props": {
        "variant": "primary",
        "text": "Neues Gerät hinzufügen"
      },
      "position": "main",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-001",
      "component_name": "Button",
      "props": {
        "variant": "outline",
        "text": "Alle Geräte synchronisieren"
      },
      "position": "main",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-001",
      "component_name": "Button",
      "props": {
        "variant": "danger",
        "text": "Gerät entfernen"
      },
      "position": "main",
      "responsive": {
        "mobile": "visible",
        "desktop": "visible"
      }
    },
    {
      "component_id": "COMP-026",
      "component_name": "ToastNotification",
