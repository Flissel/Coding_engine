  "layout": "flex column, gap-4, max-width 800px, padding 16px",
  "data_sources": [
    "GET /api/v1/devices",
    "POST /api/v1/devices",
    "PUT /api/v1/devices/{id}",
    "DELETE /api/v1/devices/{id}"
