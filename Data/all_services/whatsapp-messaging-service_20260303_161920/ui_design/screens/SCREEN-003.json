{
  "id": "SCREEN-003",
  "name": "Anrufe / Info-Status",
  "route": "/calls",
  "layout": "stack",
  "description": "Anrufliste mit Verlauf und Schnellaktionen. Nutzer kann seinen Info/Status-Text sehen und bearbeiten. Die Anrufliste zeigt vergangene Anrufe mit Kontaktinformationen und Status-Indikatoren.",
  "components": [
    "COMP-001",
    "COMP-002",
    "COMP-003",
    "COMP-009",
    "COMP-010"
  ],
  "component_layout": [
    {
