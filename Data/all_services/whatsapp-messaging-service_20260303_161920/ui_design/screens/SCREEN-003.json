-------------+|\n  26 +------------------------------------------------------------+",
  "state_bindings": {
    "COMP-002": "calls.searchQuery",
    "COMP-003": "calls.historyList",
    "COMP-009": "profile.statusInfo",
    "COMP-010": "profile.onlineStatus",
    "COMP-001": "calls.quickActions"
  },
  "navigation_rules": [
    {
      "trigger": "call_item_click",
      "target": "/contacts/{contactId}",
      "condition": ""
    },
    {
      "trigger": "new_call_click",
      "target": "/calls/new",
      "condition": ""
    },
    {
      "trigger": "video_call_click",
      "target": "/calls/new?type=video",
      "condition": ""
    },
    {
      "trigger": "edit_status_click",
      "target": "/profile/edit-status",
      "condition": "user.isAuthenticated"
    },
    {
      "trigger": "call_item_long_press",
      "target": "/calls/{callId}/details",
      "condition": ""
    },
    {
      "trigger": "search_submit",
      "target": "/calls?q={query}",
      "condition": ""
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": []
    },
    "tablet": {
      "layout": "stack",
      "hidden_components": []
    },
    "desktop": {
      "layout": "split",
      "hidden_components": []
    }
  },
  "auth_required": true
}