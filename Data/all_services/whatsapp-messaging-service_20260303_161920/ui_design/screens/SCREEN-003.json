      "name": "QuickActionButtons",
      "x": 0,
      "y": 0,
      "w": 60,
      "h": 4
    },
    {
      "id": "COMP-002",
      "name": "SearchBar",
      "x": 0,
      "y": 4,
      "w": 60,
      "h": 3
    },
    {
      "id": "COMP-009",
      "name": "ProfileStatusCard",
      "x": 0,
      "y": 7,
      "w": 60,
      "h": 5
    },
    {
      "id": "COMP-010",
      "name": "StatusIndicator",
      "x": 45,
      "y": 8,
      "w": 12,
      "h": 2
    },
    {
      "id": "COMP-003",
      "name": "CallHistoryList",
      "x": 0,
      "y": 12,
      "w": 60,
      "h": 14
    }
  ],
  "data_requirements": [
    "GET /api/calls/history",
    "GET /api/profile/status",
    "PUT /api/profile/status",
    "GET /api/contacts/{id}"
  ],
  "parent_user_story": "US-008",
