  "state_bindings": {
    "COMP-002": "dashboard.searchQuery",
    "COMP-003": "dashboard.contactStatusList",
    "COMP-009": "dashboard.selectedContact",
    "COMP-010": "dashboard.selectedContact.statusInfo",
    "COMP-001": "dashboard.selectedContact.muteAction"
  },
  "navigation_rules": [
    {
      "trigger": "contact_click",
      "target": "/dashboard",
      "condition": "contact.hasStatus"
    },
    {
      "trigger": "mute_btn_click",
      "target": "",
      "condition": "selectedContact !== null"
    },
    {
      "trigger": "unmute_tag_click",
      "target": "",
      "condition": "contact.isMuted"
    },
    {
      "trigger": "contact_long_press",
      "target": "",
      "condition": "contact.hasStatus"
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": [
        "COMP-009"
      ]
    },
    "tablet": {
      "layout": "sidebar-collapsed"
    },
    "desktop": {
      "layout": "sidebar"
    }
  },
  "auth_required": true
}