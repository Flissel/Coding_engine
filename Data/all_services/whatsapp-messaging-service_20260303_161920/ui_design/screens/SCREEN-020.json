  "navigation_rules": [
    {
      "trigger": "back_btn_click",
      "target": "/settings/profile",
      "condition": ""
    },
    {
      "trigger": "share_btn_click",
      "target": "native_share_sheet",
      "condition": ""
    },
    {
      "trigger": "scan_btn_click",
      "target": "/settings/profile/qr/scan",
      "condition": "camera.permission_granted"
    },
    {
      "trigger": "voice_call_btn_click",
      "target": "/call/voice/{contactId}",
      "condition": "contact.selected"
    },
    {
      "trigger": "camera_btn_click",
      "target": "/call/video/{contactId}",
      "condition": "call.active"
    },
    {
      "trigger": "mute_toggle",
      "target": "",
      "condition": "call.active"
    },
    {
      "trigger": "speaker_toggle",
      "target": "",
      "condition": "call.active"
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": []
    },
    "tablet": {
      "layout": "single-centered"
    },
    "desktop": {
      "layout": "single-centered"
    }
  },
  "auth_required": true
}