    "COMP-001_scan": "qr.scanAction",
    "COMP-001_call": "call.initiateAction",
    "COMP-001_mute": "call.controls.mute",
    "COMP-001_camera": "call.controls.camera",
    "COMP-001_speaker": "call.controls.speaker"
