{
  "id": "SCREEN-023",
  "name": "Biometrische Entsperrung",
  "route": "/settings/security/biometrics",
  "layout": "stack",
  "description": "Einstellungsscreen für biometrische Entsperrung mit Toggle zur Aktivierung/Deaktivierung und Berechtigungsverwaltung. Ermöglicht auch den Zugriff auf Video-Sende-Funktionalität über den Chat-Kontext.",
  "components": [
    "COMP-001",
    "COMP-007",
    "COMP-005",
    "COMP-010"
  ],
  "component_layout": [
    {
      "id": "COMP-001",
      "name": "BackButton",
      "x": 0,
      "y": 0,
      "w": 6,
      "h": 3
    },
    {
      "id": "COMP-001-2",
      "name": "BiometricToggle",
      "x": 6,
      "y": 4,
      "w": 48,
      "h": 4
    },
    {
      "id": "COMP-010",
      "name": "PermissionStatus",
      "x": 6,
      "y": 9,
      "w": 48,
      "h": 6
    },
    {
      "id": "COMP-001-3",
      "name": "SaveButton",
      "x": 15,
      "y": 16,
      "w": 30,
      "h": 3
    },
    {
      "id": "COMP-007",
      "name": "VideoPreview",
      "x": 6,
      "y": 20,
      "w": 48,
      "h": 8
    },
    {
      "id": "COMP-005",
      "name": "MessageInput",
      "x": 0,
      "y": 28,
      "w": 60,
      "h": 4
    }
  ],
  "data_requirements": [
    "GET /api/settings/security/biometrics",
    "PUT /api/settings/security/biometrics",
    "GET /api/permissions/biometrics",
    "POST /api/messages/{chatId}/video"
  ],
  "parent_user_story": "US-048",
  "wireframe_mermaid": "flowchart TD\n    subgraph Biometrische_Entsperrung\n        Header[Header / Navigation]\n        Main[Main Content Area]\n        Sidebar[Sidebar / Filters]\n        Footer[Footer / Actions]\n    end\n\n    Header --> Main\n    Sidebar --> Main\n    Main --> Footer\n\n    %% \n",
  "wireframe_ascii": "     0    5   10   15   20   25   30   35   40   45   50   55   60\n   0 +------------------------------------------------------------+\n     | [<Back]   Biometrische Entsperrung                        |\n   2 |  COMP-001                                                  |\n   3 +------------------------------------------------------------+\n   4 |      +------------------------------------------------+   |\n     |      |  Biometrische Entsperrung       [====O] Toggle  |   |\n   6 |      |  COMP-001 (BiometricToggle)                     |   |\n     |      +------------------------------------------------+   |\n   8 |                                                            |\n   9 |      +------------------------------------------------+   |\n     |      |  Berechtigungen              COMP-010           |   |\n  11 |      |  +-----------+  +---------------------------+   |   |\n     |      |  | [●] Kamera |  | [●] Fingerabdruck       |   |   |\n  13 |      |  | Erlaubt    |  | Aktiviert               |   |   |\n     |      |  +-----------+  +---------------------------+   |   |\n  15 |      +------------------------------------------------+   |\n  16 |               +------------------------------+             |\n     |               |     [Speichern]  COMP-001    |             |\n  18 |               +------------------------------+             |\n  19 |  - - - - - - - - - - - - - - - - - - - - - - - - - - - -  |\n  20 |      +------------------------------------------------+   |\n     |      |                                                |   |\n  22 |      |        [Video-Vorschau / Player]               |   |\n     |      |           COMP-007 (MediaViewer)               |   |\n  24 |      |        +------------------+                    |   |\n     |      |        |   advancement_bar |  00:32 / 01:15    |   |\n  26 |      |        +------------------+                    |   |\n     |      +------------------------------------------------+   |\n  28 +------------------------------------------------------------+\n     | [+] | [Nachricht / Video-Caption eingeben]    | [>Send]    |\n  30 |     |       COMP-005 (MessageInput)           | COMP-001   |\n     +------------------------------------------------------------+\n  32 +------------------------------------------------------------+",
  "state_bindings": {
    "COMP-001-2": "settings.biometrics.enabled",
    "COMP-010": "settings.biometrics.permissions",
    "COMP-007": "chat.currentVideo",
    "COMP-005": "chat.videoCaption"
  },
  "navigation_rules": [
    {
      "trigger": "back_btn_click",
      "target": "/settings/security",
      "condition": ""
    },
    {
      "trigger": "save_btn_click",
      "target": "/settings/security",
      "condition": "settings.biometrics.changed"
    },
    {
      "trigger": "send_btn_click",
      "target": "/chat/{chatId}",
      "condition": "chat.currentVideo !== null"
    },
    {
      "trigger": "video_attach_click",
      "target": "/chat/{chatId}/media/video-picker",
      "condition": "permissions.camera.granted"
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": []
    },
    "tablet": {
      "layout": "stack"
    },
    "desktop": {
      "layout": "stack"
    }
  },
  "auth_required": true
}