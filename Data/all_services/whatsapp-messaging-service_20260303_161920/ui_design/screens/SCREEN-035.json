{
  "id": "SCREEN-035",
  "name": "Account Recovery Dashboard",
  "route": "/dashboard/account-recovery",
  "layout": "single-column",
  "description": "Dashboard screen for account recovery and phone number change after device loss. Allows users to verify identity, recover their account, and update their registered phone number.",
  "components": [
    "COMP-001",
    "COMP-002",
    "COMP-009",
    "COMP-010"
  ],
  "component_layout": [
    {
      "id": "COMP-010",
      "name": "RecoveryStatusIndicator",
      "x": 0,
      "y": 0,
      "w": 60,
      "h": 4
    },
    {
      "id": "COMP-002",
      "name": "PhoneNumberSearch",
      "x": 2,
      "y": 5,
      "w": 56,
      "h": 3
    },
    {
      "id": "COMP-009",
      "name": "AccountInfoCard",
      "x": 2,
      "y": 9,
      "w": 56,
      "h": 10
    },
    {
      "id": "COMP-001",
      "name": "ActionButtons",
      "x": 2,
      "y": 20,
      "w": 56,
      "h": 4
    }
  ],
  "data_requirements": [
    "GET /api/account/recovery/status",
    "POST /api/account/recovery/initiate",
    "POST /api/account/recovery/verify",
    "PUT /api/account/phone-number",
    "GET /api/account/profile"
  ],
  "parent_user_story": "US-133",
  "wireframe_mermaid": "flowchart TD\n    subgraph Account_Recovery_Dashboard\n        Header[Header / Navigation]\n        Main[Main Content Area]\n        Sidebar[Sidebar / Filters]\n        Footer[Footer / Actions]\n    end\n\n    Header --> Main\n    Sidebar --> Main\n    Main --> Footer\n\n    %% \n",
  "wireframe_ascii": "     0    5   10   15   20   25   30   35   40   45   50   55   60\n   0 +------------------------------------------------------------+\n     |  COMP-010  [StatusIndicator]                              |\n   2 |  Recovery Status: [●] Identity Verification Pending       |\n     |  Step 2 of 4  =========>-----------  (Progress Bar)       |\n   4 +------------------------------------------------------------+\n   5 |                                                            |\n     |  +--------------------------------------------------------+|\n   6 |  | COMP-002  [PhoneNumberSearch]                          ||\n     |  | [🔍 Enter your registered or new phone number...    ]  ||\n   8 |  +--------------------------------------------------------+|\n   9 |                                                            |\n     |  +--------------------------------------------------------+|\n  10 |  | COMP-009  [AccountInfoCard]                            ||\n     |  |                                                        ||\n  11 |  |  +--------+  Account Details                           ||\n     |  |  | Avatar |  Name:   John Doe                          ||\n  12 |  |  |  [👤]  |  Phone:  +49 170 ***-**42 (old)            ||\n     |  |  +--------+  Status: Recovery in Progress              ||\n  13 |  |                                                        ||\n     |  |  +-------------------------------------------------+   ||\n  14 |  |  | New Phone Number:                                |   ||\n     |  |  | [ +49  ] [  Enter new number__________________ ] |   ||\n  15 |  |  +-------------------------------------------------+   ||\n     |  |                                                        ||\n  16 |  |  Verification Method:                                  ||\n     |  |  (●) SMS Code   ( ) Email Link   ( ) Backup Code      ||\n  17 |  |                                                        ||\n  18 |  |  [ _ ] [ _ ] [ _ ] [ _ ] [ _ ] [ _ ]  (OTP Input)      ||\n     |  |                                                        ||\n  19 |  +--------------------------------------------------------+|\n  20 |                                                            |\n     |  +---------------------------+  +-------------------------+|\n  21 |  | COMP-001                  |  | COMP-001                ||\n     |  | [🔄 Verify & Recover    ] |  | [📱 Change Number     ]||\n  22 |  |   (Primary Button)        |  |   (Secondary Button)   ||\n     |  +---------------------------+  +-------------------------+|\n  23 |                                                            |\n     |  +--------------------------------------------------------+|\n  24 |  | COMP-001  [ Cancel Recovery ]  (Tertiary/Link Button)  ||\n     |  +--------------------------------------------------------+|\n  25 +------------------------------------------------------------+",
  "state_bindings": {
    "COMP-010": "recovery.status",
    "COMP-002": "recovery.phoneSearch",
    "COMP-009": "recovery.accountInfo",
    "COMP-001": "recovery.actions"
  },
  "navigation_rules": [
    {
      "trigger": "verify_recover_click",
      "target": "/dashboard/account-recovery/verify",
      "condition": "recovery.otpEntered && recovery.newPhoneValid"
    },
    {
      "trigger": "change_number_click",
      "target": "/dashboard/account-recovery/change-number",
      "condition": "recovery.identityVerified"
    },
    {
      "trigger": "cancel_click",
      "target": "/dashboard",
      "condition": ""
    },
    {
      "trigger": "recovery_complete",
      "target": "/dashboard",
      "condition": "recovery.status === 'completed'"
    },
    {
      "trigger": "search_submit",
      "target": "",
      "condition": "recovery.phoneSearch.length >= 6"
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": []
    },
    "tablet": {
      "layout": "single-column"
    },
    "desktop": {
      "layout": "single-column"
    }
  },
  "auth_required": true
}