{
  "id": "SCREEN-031",
  "name": "Unknown Senders Dashboard",
  "route": "/dashboard/unknown-senders",
  "layout": "sidebar",
  "description": "Dashboard-Ansicht zur separaten Anzeige und Verwaltung von Nachrichten unbekannter Absender. Ermöglicht das Filtern, Durchsuchen, Blockieren und Hinzufügen zu Kontakten.",
  "components": [
    "COMP-001",
    "COMP-002",
    "COMP-003",
    "COMP-009",
    "COMP-010"
  ],
  "component_layout": [
    {
      "id": "header-bar",
      "name": "HeaderBar",
      "x": 0,
      "y": 0,
      "w": 60,
      "h": 4
    },
    {
      "id": "COMP-002",
      "name": "SearchBar",
      "x": 0,
      "y": 4,
      "w": 20,
      "h": 3
    },
    {
      "id": "COMP-010",
      "name": "StatusFilter",
      "x": 0,
      "y": 7,
      "w": 20,
      "h": 5
    },
    {
      "id": "COMP-001",
      "name": "ActionButtons",
      "x": 0,
      "y": 12,
      "w": 20,
      "h": 4
    },
    {
      "id": "COMP-003",
      "name": "UnknownSenderList",
      "x": 21,
      "y": 4,
      "w": 39,
      "h": 12
    },
    {
      "id": "COMP-009",
      "name": "ContactCard",
      "x": 21,
      "y": 16,
      "w": 39,
      "h": 8
    }
  ],
  "data_requirements": [
    "GET /api/messages/unknown-senders",
    "GET /api/messages/unknown-senders?search={query}",
    "GET /api/messages/unknown-senders/{senderId}",
    "POST /api/contacts (add unknown sender to contacts)",
    "POST /api/messages/unknown-senders/{senderId}/block",
    "DELETE /api/messages/unknown-senders/{senderId}"
  ],
  "parent_user_story": "US-075",
  "wireframe_mermaid": "flowchart TD\n    subgraph Unknown_Senders_Dashboard\n        Header[Header / Navigation]\n        Main[Main Content Area]\n        Sidebar[Sidebar / Filters]\n        Footer[Footer / Actions]\n    end\n\n    Header --> Main\n    Sidebar --> Main\n    Main --> Footer\n\n    %% \n",
