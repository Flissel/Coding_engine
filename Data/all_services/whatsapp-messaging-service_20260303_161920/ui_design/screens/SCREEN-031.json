  "state_bindings": {
    "COMP-002": "unknownSenders.searchQuery",
    "COMP-003": "unknownSenders.list",
    "COMP-009": "unknownSenders.selectedSenderDetail",
    "COMP-010": "unknownSenders.statusFilter",
    "COMP-001": "unknownSenders.actions"
  },
  "navigation_rules": [
    {
      "trigger": "list_item_click",
      "target": "/dashboard/unknown-senders/{senderId}",
      "condition": ""
    },
    {
      "trigger": "add_contact_click",
      "target": "/contacts/new?phone={senderPhone}",
      "condition": ""
    },
    {
      "trigger": "block_click",
      "target": "",
      "condition": "confirm('Absender blockieren?')"
    },
    {
      "trigger": "delete_click",
      "target": "",
      "condition": "confirm('Nachrichten löschen?')"
    },
    {
      "trigger": "back_click",
      "target": "/dashboard",
      "condition": ""
    },
    {
      "trigger": "open_chat_click",
      "target": "/chat/{senderId}",
      "condition": "sender.isNotBlocked"
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": [
        "COMP-009"
      ],
      "notes": "Liste nimmt volle Breite ein, ContactCard öffnet als Bottom-Sheet bei Tap"
    },
    "tablet": {
      "layout": "sidebar-collapsed",
      "notes": "Sidebar als Overlay, Liste und Detail nebeneinander"
    },
    "desktop": {
      "layout": "sidebar",
      "notes": "Volle Drei-Spalten-Ansicht mit Filter, Liste und Detail"
    }
  },
  "auth_required": true
}