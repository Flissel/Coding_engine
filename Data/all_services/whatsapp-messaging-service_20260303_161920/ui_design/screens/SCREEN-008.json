  "state_bindings": {
    "COMP-002": "groupAdmin.searchQuery",
    "COMP-009": "groupAdmin.selectedMember",
    "COMP-010": "groupAdmin.memberStatus",
    "COMP-003": "groupAdmin.memberList",
    "COMP-001": "groupAdmin.actions"
  },
  "navigation_rules": [
    {
      "trigger": "back_btn_click",
      "target": "/settings/security",
      "condition": ""
    },
    {
      "trigger": "member_click",
      "target": "/settings/security/group-admin/member/{memberId}",
      "condition": ""
    },
    {
      "trigger": "add_member_click",
      "target": "/settings/security/group-admin/add-member",
      "condition": "user.isGroupAdmin"
    },
    {
      "trigger": "remove_member_click",
      "target": "",
      "condition": "user.isGroupAdmin && member.role !== 'admin'"
    },
    {
      "trigger": "security_toggle_click",
      "target": "/settings/security/group-admin/permissions",
      "condition": "user.isGroupAdmin"
    },
    {
      "trigger": "save_btn_click",
      "target": "/settings/security",
      "condition": "groupAdmin.hasChanges"
    },
    {
      "trigger": "cancel_btn_click",
      "target": "/settings/security",
      "condition": ""
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": [],
      "notes": "Mitgliederliste wird vollbreit, Buttons stacken vertikal, Rollen-Dropdown wird zu Bottom-Sheet"
    },
    "tablet": {
      "layout": "single-column",
      "notes": "Leicht komprimierte Darstellung, alle Elemente sichtbar"
    },
    "desktop": {
      "layout": "single-column",
      "notes": "Volle Breite mit allen Details inline dargestellt"
    }
  },
  "auth_required": true
}