  "state_bindings": {
    "COMP-002": "dashboard.chatSearch",
    "COMP-003": "dashboard.chatList",
    "COMP-009": "dashboard.selectedContact",
    "COMP-010": "dashboard.connectionStatus",
    "COMP-001": "dashboard.exportAction"
  },
  "navigation_rules": [
    {
      "trigger": "chat_list_item_click",
      "target": "/dashboard?chat={id}",
      "condition": ""
    },
    {
      "trigger": "export_btn_click",
      "target": "",
      "condition": "chat.selected"
    },
    {
      "trigger": "export_confirm_click",
      "target": "",
      "condition": "export.formatSelected"
    },
    {
      "trigger": "export_complete",
      "target": "/dashboard?exported={id}",
      "condition": "export.success"
    },
    {
      "trigger": "cancel_btn_click",
      "target": "/dashboard",
      "condition": ""
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": [
        "COMP-009"
      ]
    },
    "tablet": {
      "layout": "sidebar-collapsed"
    },
    "desktop": {
      "layout": "sidebar"
    }
  },
  "auth_required": true
}