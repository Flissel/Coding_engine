{
  "id": "SCREEN-039",
  "name": "Dashboard - Chat Export",
  "route": "/dashboard",
  "layout": "sidebar",
  "description": "Dashboard-Ansicht mit Chat-Liste, Chat-Vorschau und Export-Funktionalität. Ermöglicht dem Nutzer einen einzelnen Chat auszuwählen und zu exportieren.",
  "components": [
    "COMP-001",
    "COMP-002",
    "COMP-003",
    "COMP-009",
    "COMP-010"
  ],
  "component_layout": [
    {
      "id": "COMP-002",
      "name": "SearchBar",
      "x": 0,
      "y": 0,
      "w": 20,
      "h": 3
    },
    {
      "id": "COMP-003",
      "name": "ChatListItem",
      "x": 0,
      "y": 3,
      "w": 20,
      "h": 18
    },
    {
      "id": "COMP-010",
      "name": "StatusIndicator",
      "x": 16,
      "y": 4,
      "w": 4,
      "h": 1
    },
    {
      "id": "COMP-009",
      "name": "ContactCard",
      "x": 21,
      "y": 0,
      "w": 39,
      "h": 5
    },
    {
      "id": "COMP-001",
      "name": "ExportButton",
      "x": 50,
      "y": 1,
      "w": 10,
      "h": 2
    }
  ],
  "data_requirements": [
    "GET /api/chats",
    "GET /api/chats/{id}",
    "GET /api/chats/{id}/messages",
    "POST /api/chats/{id}/export",
    "GET /api/contacts/{id}"
  ],
  "parent_user_story": "US-092",
