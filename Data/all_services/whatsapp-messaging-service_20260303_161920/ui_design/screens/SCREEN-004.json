  "navigation_rules": [
    {
      "trigger": "back_btn_click",
      "target": "/settings",
      "condition": ""
    },
    {
      "trigger": "save_btn_click",
      "target": "/settings/notifications",
      "condition": "notifications.isDirty"
    },
    {
      "trigger": "chat_item_click",
      "target": "/settings/notifications/chat/{chatId}",
      "condition": ""
    },
    {
      "trigger": "master_toggle_off",
      "target": "",
      "condition": "disables_all_sub_toggles"
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": [],
      "notes": "Full width toggles, scrollable chat list, sticky header with back/save buttons"
    },
    "tablet": {
      "layout": "stack",
      "notes": "Centered content with max-width 600px, larger toggle hit areas"
    },
    "desktop": {
      "layout": "stack",
      "notes": "Embedded within settings sidebar layout at /settings, max-width 640px centered"
    }
  },
  "auth_required": true
}