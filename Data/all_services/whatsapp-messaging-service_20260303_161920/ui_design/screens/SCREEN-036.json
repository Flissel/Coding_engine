  "state_bindings": {
    "COMP-002": "dashboard.searchQuery",
    "COMP-003": "dashboard.chatList",
    "COMP-009": "profile.userData",
    "COMP-001": "profile.qrActions",
    "COMP-010": "profile.onlineStatus"
  },
  "navigation_rules": [
    {
      "trigger": "chat_item_click",
      "target": "/chat/{chatId}",
      "condition": ""
    },
    {
      "trigger": "generate_qr_click",
      "target": "",
      "condition": "user.isAuthenticated"
    },
    {
      "trigger": "share_qr_click",
      "target": "",
      "condition": "profile.qrCode !== null"
    },
    {
      "trigger": "save_qr_click",
      "target": "",
      "condition": "profile.qrCode !== null"
    },
    {
      "trigger": "search_submit",
      "target": "/dashboard?q={query}",
      "condition": ""
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": [
        "COMP-003",
        "COMP-002"
      ]
    },
    "tablet": {
      "layout": "sidebar-collapsed"
    },
    "desktop": {
      "layout": "sidebar"
    }
  },
  "auth_required": true
}