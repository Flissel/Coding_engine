{
  "id": "SCREEN-036",
  "name": "Dashboard - QR-Code Profil",
  "route": "/dashboard",
  "layout": "sidebar",
  "description": "Dashboard-Screen mit QR-Code Profil-Generierung. Der Nutzer kann seinen persönlichen QR-Code generieren, anzeigen und teilen lassen, damit andere sein Profil scannen können.",
  "components": [
    "COMP-001",
    "COMP-002",
    "COMP-003",
    "COMP-009",
    "COMP-010"
  ],
  "component_layout": [
    {
      "id": "COMP-002",
      "name": "SearchBar",
      "x": 0,
      "y": 0,
      "w": 15,
      "h": 3
    },
    {
      "id": "COMP-003",
      "name": "ChatListItem",
      "x": 0,
      "y": 3,
      "w": 15,
      "h": 17
    },
    {
      "id": "COMP-010",
      "name": "StatusIndicator",
      "x": 0,
      "y": 20,
      "w": 15,
      "h": 2
    },
    {
      "id": "COMP-009",
      "name": "ContactCard (Profil + QR)",
      "x": 16,
      "y": 0,
      "w": 44,
      "h": 16
    },
    {
      "id": "COMP-001",
      "name": "Button (QR Actions)",
      "x": 16,
      "y": 16,
      "w": 44,
      "h": 6
    }
  ],
  "data_requirements": [
    "GET /api/profile",
    "GET /api/profile/qr-code",
    "POST /api/profile/qr-code/generate",
    "GET /api/chats"
  ],
  "parent_user_story": "US-010",
  "wireframe_mermaid": "flowchart TD\n    subgraph Dashboard_-_QR-Code_Profil\n        Header[Header / Navigation]\n        Main[Main Content Area]\n        Sidebar[Sidebar / Filters]\n        Footer[Footer / Actions]\n    end\n\n    Header --> Main\n    Sidebar --> Main\n    Main --> Footer\n\n    %% \n",
