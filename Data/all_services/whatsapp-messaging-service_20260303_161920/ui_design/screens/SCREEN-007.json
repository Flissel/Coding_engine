  "state_bindings": {
    "COMP-010": "profile.status",
    "COMP-006": "audio.recording",
    "COMP-007": "audio.preview",
    "COMP-005": "audio.caption"
  },
  "navigation_rules": [
    {
      "trigger": "back_btn_click",
      "target": "/settings",
      "condition": ""
    },
    {
      "trigger": "save_btn_click",
      "target": "/settings/profile",
      "condition": "profile.isDirty"
    },
    {
      "trigger": "send_audio_click",
      "target": "/chat/{chatId}",
      "condition": "audio.isReady"
    },
    {
      "trigger": "record_complete",
      "target": "",
      "condition": "audio.duration > 0"
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": []
    },
    "tablet": {
      "layout": "single-column"
    },
    "desktop": {
      "layout": "single-column"
    }
  },
  "auth_required": true
}