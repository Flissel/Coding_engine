  "state_bindings": {
    "COMP-009": "profile.user",
    "COMP-010": "profile.user.status",
    "COMP-002": "chats.searchQuery",
    "COMP-003": "chats.list",
    "COMP-001": "chats.actions.newChat"
  },
  "navigation_rules": [
    {
      "trigger": "chat_item_click",
      "target": "/chat/{chatId}",
      "condition": ""
    },
    {
      "trigger": "new_chat_click",
      "target": "/chat/new",
      "condition": "user.isAuthenticated"
    },
    {
      "trigger": "profile_edit_click",
      "target": "/profile/edit",
      "condition": ""
    },
    {
      "trigger": "search_submit",
      "target": "/dashboard?search={query}",
      "condition": ""
    }
  ],
  "responsive": {
    "mobile": {
      "layout": "stack",
      "hidden_components": [
        "COMP-009"
      ]
    },
    "tablet": {
      "layout": "sidebar-collapsed"
    },
    "desktop": {
      "layout": "sidebar"
    }
  },
  "auth_required": true
}